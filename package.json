{
  "name": "pi-comfort",
  "version": "0.1.0",
  "description": "Personal Pi comfort extensions and configuration experiments.",
  "type": "module",
  "private": true,
  "keywords": ["pi-package", "pi", "pi-extension", "comfort", "workflow"],
  "pi": {
    "extensions": ["./extensions"]
